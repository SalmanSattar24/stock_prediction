# ============================================
# STOCK SIGNAL SYSTEM - API KEYS TEMPLATE
# ============================================
#
# IMPORTANT SECURITY NOTES:
# 1. Never commit .env to version control
# 2. Keep your actual .env file private
# 3. Use different keys for dev/prod environments
# 4. Rotate keys regularly
# 5. Revoke compromised keys immediately
#

# ============================================
# FINANCIAL DATA SOURCES
# ============================================

# Finnhub (Real-time stock quotes, company data)
# Free tier: 60 API calls/minute
# Get key: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage (Stock data, earnings, forex)
# Free tier: 5 calls/minute, 500/day
# Get key: https://www.alphavantage.co/
ALPHAVANTAGE_KEY=your_alphavantage_key_here

# EODHD (End of day historical data)
# Free tier: 20 requests/day
# Get key: https://eodhd.com/
EODHD_KEY=your_eodhd_key_here

# ============================================
# NEWS & SENTIMENT SOURCES
# ============================================

# NewsAPI (Financial news sentiment)
# Free tier: 100 requests/day
# Get key: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# ============================================
# SOCIAL MEDIA & COMMUNITY
# ============================================

# Reddit API (r/wallstreetbets, r/stocks sentiment)
# Setup instructions:
#   1. Go to https://www.reddit.com/prefs/apps
#   2. Click "Create an app" or "Create another app"
#   3. Choose "script" for personal use
#   4. Fill in name and description
#   5. Set redirect URI to http://localhost:8080
#   6. Copy your Client ID and Client Secret below
#
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=QuantSignalSystem/1.0 by YourRedditUsername

# Twitter/X (Optional - for social sentiment)
# TWITTER_API_KEY=your_twitter_key_here
# TWITTER_API_SECRET=your_twitter_secret_here
# TWITTER_BEARER_TOKEN=your_bearer_token_here

# ============================================
# BROKER INTEGRATION (OPTIONAL)
# ============================================

# Alpaca (Paper and live trading)
# ALPACA_API_KEY=your_alpaca_key_here
# ALPACA_SECRET_KEY=your_alpaca_secret_here

# Interactive Brokers
# IB_ACCOUNT=your_ib_account_here
# IB_PASSWORD=your_ib_password_here

# ============================================
# SYSTEM CONFIGURATION
# ============================================

# Development environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# System settings
INITIAL_CAPITAL=100000
RISK_PER_TRADE=0.02
MAX_POSITION_SIZE=0.05
